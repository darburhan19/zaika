# Backend
NODE_ENV=development
PORT=5000

# Mongo
MONGODB_URI=

# CORS
# Set either CORS_ORIGIN or CLIENT_URL (both are used)
CORS_ORIGIN=http://localhost:5173,https://zaika-topaz.vercel.app
CLIENT_URL=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
RESERVATION_OTP_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Backward-compatible aliases used by older configs
RAZORPAY_KEY=
RAZORPAY_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Backward-compatible aliases used by older configs
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Email (for password reset / notifications)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
